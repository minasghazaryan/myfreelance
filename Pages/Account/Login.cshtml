@page
@model MyFreelance.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign in";
    Layout = "_AuthLayout";
}

<div class="auth-card">
    <div class="auth-header">
        <span class="auth-badge">Welcome back</span>
        <h1>Sign in to MyFreelance</h1>
        <p>Manage your team and assigned work in one place.</p>
    </div>

    <form method="post" class="auth-form">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="form-floating mb-3">
            <input asp-for="Input.Email" class="form-control" placeholder="name@company.com" />
            <label asp-for="Input.Email"></label>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <div class="form-floating mb-3">
            <input asp-for="Input.Password" class="form-control" placeholder="Password" />
            <label asp-for="Input.Password"></label>
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>

        <div class="form-check mb-4">
            <input asp-for="Input.RememberMe" class="form-check-input" />
            <label asp-for="Input.RememberMe" class="form-check-label"></label>
        </div>

        <button type="submit" class="btn btn-gradient w-100 mb-3">Sign in</button>
        <p class="text-center mb-0 auth-footer-text">
            New here? <a asp-page="/Account/Register">Create an account</a>
        </p>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
