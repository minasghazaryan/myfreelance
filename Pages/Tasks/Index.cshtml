@page
@model MyFreelance.Pages.Tasks.IndexModel
@{
    ViewData["Title"] = "Tasks";
}

<div class="page-header d-flex flex-wrap justify-content-between align-items-end gap-3">
    <div>
        <span class="page-eyebrow">Assignments</span>
        <h1>Tasks</h1>
        <p>Track work assigned to your hired team.</p>
    </div>
    @if (Model.CanManage)
    {
        <a asp-page="Create" class="btn btn-gradient">+ Assign task</a>
    }
</div>

@if (TempData["SuccessMessage"] is string message)
{
    <div class="alert alert-success glass-alert">@message</div>
}

@if (Model.Tasks.Count == 0)
{
    <div class="empty-state">
        <h3>No tasks yet</h3>
        <p>@(Model.CanManage ? "Assign your first task to a team member." : "You have no assigned tasks right now.")</p>
        @if (Model.CanManage)
        {
            <a asp-page="Create" class="btn btn-gradient">Assign task</a>
        }
    </div>
}
else
{
    <div class="glass-card table-card">
        <div class="table-responsive">
            <table class="table task-table mb-0">
                <thead>
                    <tr>
                        <th>Task</th>
                        @if (Model.CanManage)
                        {
                            <th>Assignee</th>
                        }
                        <th>Status</th>
                        <th>Due</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in Model.Tasks)
                    {
                        <tr>
                            <td>
                                <strong>@task.Title</strong>
                                @if (!string.IsNullOrWhiteSpace(task.Description))
                                {
                                    <div class="small text-muted text-truncate" style="max-width: 320px;">@task.Description</div>
                                }
                            </td>
                            @if (Model.CanManage)
                            {
                                <td>@task.AssigneeName</td>
                            }
                            <td><span class="status-badge status-@task.Status.ToString().ToLower()">@task.Status</span></td>
                            <td>@(task.DueDate?.ToLocalTime().ToString("MMM d, yyyy") ?? "—")</td>
                            <td class="text-end">
                                <a asp-page="Details" asp-route-id="@task.Id" class="btn btn-sm btn-outline-light">Open</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
