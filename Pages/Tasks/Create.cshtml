@page
@model MyFreelance.Pages.Tasks.CreateModel
@{
    ViewData["Title"] = "Assign task";
}

<div class="page-header">
    <span class="page-eyebrow">Assignments</span>
    <h1>Assign a task</h1>
    <p>Create work and assign it to someone on your hired team.</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="glass-card form-card">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Title" class="form-control" placeholder="Design landing page" />
                    <label asp-for="Input.Title"></label>
                    <span asp-validation-for="Input.Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Description" class="form-label"></label>
                    <textarea asp-for="Input.Description" class="form-control" rows="4" placeholder="Describe the task..."></textarea>
                    <span asp-validation-for="Input.Description" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.AssignedToUserId" class="form-label"></label>
                    <select asp-for="Input.AssignedToUserId" asp-items="Model.Assignees" class="form-select">
                        <option value="">Select team member</option>
                    </select>
                    <span asp-validation-for="Input.AssignedToUserId" class="text-danger"></span>
                </div>

                <div class="form-floating mb-4">
                    <input asp-for="Input.DueDate" class="form-control" />
                    <label asp-for="Input.DueDate"></label>
                    <span asp-validation-for="Input.DueDate" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-gradient">Assign task</button>
                    <a asp-page="Index" class="btn btn-outline-light">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
