@page
@model MyFreelance.Web.Areas.Admin.Pages.Tiers.IndexModel
@{ ViewData["Title"] = "Investment Tiers"; }

<div class="dashboard-layout">
    <div class="container-fluid">
        <div class="row">
            <partial name="Shared/_AdminNav" />
            <div class="col-lg-10 p-4">
                <h2 class="text-gold mb-4">Investment Tier Management</h2>
                <div class="aurum-card mb-4">
                    <h5 class="text-gold">Add Tier</h5>
                    <form method="post" class="row g-3 mt-2">
                        <div class="col-md-3"><input asp-for="Input.Name" class="form-control form-control-aurum" placeholder="Name" required /></div>
                        <div class="col-md-2"><input asp-for="Input.ProjectedYieldPercent" type="number" step="0.1" class="form-control form-control-aurum" placeholder="Yield %" required /></div>
                        <div class="col-md-2"><input asp-for="Input.MinInvestment" type="number" class="form-control form-control-aurum" placeholder="Min" required /></div>
                        <div class="col-md-2"><input asp-for="Input.MaxInvestment" type="number" class="form-control form-control-aurum" placeholder="Max" required /></div>
                        <div class="col-md-3"><input asp-for="Input.Description" class="form-control form-control-aurum" placeholder="Description" /></div>
                        <div class="col-12"><button type="submit" class="btn btn-aurum">Create Tier</button></div>
                    </form>
                </div>
                <table class="table table-aurum">
                    <thead><tr><th>Name</th><th>Yield</th><th>Min</th><th>Max</th><th>Risk</th><th></th></tr></thead>
                    <tbody>@foreach (var t in Model.Tiers) { <tr><td>@t.Name</td><td>@t.ProjectedYieldPercent%</td><td>$@t.MinInvestment</td><td>$@t.MaxInvestment</td><td>@t.RiskLevel</td><td><form method="post" asp-page-handler="Delete"><input type="hidden" name="id" value="@t.Id" /><button class="btn btn-sm btn-danger">Delete</button></form></td></tr> }</tbody>
                </table>
            </div>
        </div>
    </div>
</div>
