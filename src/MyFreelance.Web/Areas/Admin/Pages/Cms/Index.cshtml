@page
@model MyFreelance.Web.Areas.Admin.Pages.Cms.IndexModel
@{ ViewData["Title"] = "CMS"; }

<div class="dashboard-layout">
    <div class="container-fluid">
        <div class="row">
            <partial name="Shared/_AdminNav" />
            <div class="col-lg-10 p-4">
                <h2 class="text-gold mb-4">Content Management</h2>
                <form method="post" class="aurum-card mb-4">
                    <input asp-for="Input.Slug" class="form-control form-control-aurum mb-2" placeholder="slug" required />
                    <input asp-for="Input.Title" class="form-control form-control-aurum mb-2" placeholder="Title" required />
                    <textarea asp-for="Input.Content" class="form-control form-control-aurum mb-2" rows="5" placeholder="HTML content"></textarea>
                    <button type="submit" class="btn btn-aurum">Add Page</button>
                </form>
                @foreach (var p in Model.Pages) { <div class="aurum-card mb-2"><a asp-page="/Cms/Page" asp-route-slug="@p.Slug" class="text-gold">@p.Title</a></div> }
            </div>
        </div>
    </div>
</div>
