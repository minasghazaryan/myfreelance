<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AurumWealth</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="@(ViewData["BodyClass"] ?? "")">
    @if (ViewData["HideNav"] as bool? != true)
    {
        <nav class="navbar navbar-expand-lg navbar-dark aurum-nav fixed-top">
            <div class="container">
                <a class="navbar-brand aurum-brand" asp-page="/Index">
                    <i class="bi bi-gem me-2"></i>Aurum<span class="text-gold">Wealth</span>
                </a>
                <button class="navbar-toggler border-gold" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navMain">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-3">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item"><a class="nav-link" asp-page="/Dashboard/Index">Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/Dashboard/Investments">Invest</a></li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item"><a class="nav-link text-gold" asp-area="Admin" asp-page="/Index">Admin</a></li>
                            }
                            <li class="nav-item">
                                <form method="post" asp-page="/Account/Logout" class="d-inline">
                                    <button type="submit" class="btn btn-aurum-outline btn-sm">Sign Out</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" href="#how-it-works">How It Works</a></li>
                            <li class="nav-item"><a class="nav-link" href="#tiers">Tiers</a></li>
                            <li class="nav-item"><a class="nav-link" href="#faq">FAQ</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/Account/Login">Sign In</a></li>
                            <li class="nav-item"><a class="btn btn-aurum ms-lg-2" asp-page="/Account/Register">Start Investing</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    }
    <main role="main">
        @RenderBody()
    </main>
    @if (ViewData["HideFooter"] as bool? != true)
    {
        <footer class="aurum-footer">
            <div class="container py-5">
                <div class="row g-4">
                    <div class="col-lg-4">
                        <h5 class="text-gold aurum-brand">AurumWealth</h5>
                        <p class="text-muted-light small">Premium blockchain investment platform. Projected yields — not guaranteed returns.</p>
                    </div>
                    <div class="col-lg-4">
                        <h6 class="text-gold">Legal</h6>
                        <ul class="list-unstyled small">
                            <li><a asp-page="/Cms/Page" asp-route-slug="terms">Terms of Service</a></li>
                            <li><a asp-page="/Cms/Page" asp-route-slug="privacy">Privacy Policy</a></li>
                        </ul>
                    </div>
                    <div class="col-lg-4">
                        <h6 class="text-gold">Contact</h6>
                        <p class="small text-muted-light mb-1"><i class="bi bi-envelope me-2"></i>support@aurumwealth.gh</p>
                        <p class="small text-muted-light mb-1"><i class="bi bi-whatsapp me-2"></i>+233 20 123 4567</p>
                    </div>
                </div>
                <hr class="border-gold-subtle my-4" />
                <p class="text-center small text-muted-light mb-0">&copy; @DateTime.UtcNow.Year AurumWealth. All investments carry risk.</p>
            </div>
        </footer>
    }
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
