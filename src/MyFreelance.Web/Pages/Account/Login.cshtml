@page
@model MyFreelance.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign In";
    ViewData["HideNav"] = true;
    ViewData["HideFooter"] = true;
}

<div class="auth-wrapper">
    <div class="auth-card aurum-card">
        <div class="text-center mb-4">
            <h2 class="text-gold aurum-brand">Welcome Back</h2>
            <p class="text-muted-light small">Sign in to your AurumWealth account</p>
        </div>
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label"></label>
                <input asp-for="Input.Email" class="form-control form-control-aurum" />
            </div>
            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label"></label>
                <input asp-for="Input.Password" class="form-control form-control-aurum" />
            </div>
            <div class="form-check mb-3">
                <input asp-for="Input.RememberMe" class="form-check-input" />
                <label asp-for="Input.RememberMe" class="form-check-label text-muted-light">Remember me</label>
            </div>
            <button type="submit" class="btn btn-aurum w-100">Sign In</button>
            <div class="d-flex justify-content-between mt-3 small">
                <a asp-page="/Account/ForgotPassword" class="text-gold">Forgot password?</a>
                <a asp-page="/Account/Register" class="text-gold">Create account</a>
            </div>
        </form>
    </div>
</div>
