@page
@{ ViewData["Title"] = "Check Your Email"; ViewData["HideNav"] = true; ViewData["HideFooter"] = true; }

<div class="auth-wrapper">
    <div class="auth-card aurum-card text-center">
        <i class="bi bi-envelope-check text-gold" style="font-size: 3rem;"></i>
        <h2 class="text-gold mt-3">Check Your Email</h2>
        <p class="text-muted-light">If an account exists, a password reset link has been sent.</p>
        <a asp-page="/Account/Login" class="btn btn-aurum mt-3">Back to Sign In</a>
    </div>
</div>
