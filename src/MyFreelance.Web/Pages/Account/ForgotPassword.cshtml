@page
@model MyFreelance.Web.Pages.Account.ForgotPasswordModel
@{ ViewData["Title"] = "Forgot Password"; ViewData["HideNav"] = true; ViewData["HideFooter"] = true; }

<div class="auth-wrapper">
    <div class="auth-card aurum-card">
        <h2 class="text-gold text-center mb-4">Reset Password</h2>
        <form method="post">
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">Email</label>
                <input asp-for="Input.Email" class="form-control form-control-aurum" />
            </div>
            <button type="submit" class="btn btn-aurum w-100">Send Reset Link</button>
        </form>
    </div>
</div>
